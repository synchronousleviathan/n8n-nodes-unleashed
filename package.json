{
  "name": "@synchronousleviathan/n8n-nodes-unleashed",
  "version": "1.2.2",
  "description": "n8n community node for Unleashed inventory management software",
  "keywords": [
    "n8n-community-node-package",
    "unleashed",
    "inventory",
    "sales-orders",
    "invoices",
    "erp"
  ],
  "license": "MIT",
  "homepage": "https://github.com/synchronousleviathan/n8n-nodes-unleashed",
  "author": {
    "name": "Synchronous Leviathan"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/synchronousleviathan/n8n-nodes-unleashed.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node build.js",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/UnleashedApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Unleashed/Unleashed.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "@typescript-eslint/parser": "~8.32.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "n8n-workflow": "^1.82.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
